# Database connection (defaults match standard DwemerDistro setup)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dwemer
DB_USER=dwemer
DB_PASSWORD=dwemer
# Optional secondary database target used by run_query when database="stobe"
STOBE_DB_NAME=stobe

# MCP Server port (all other config in PostgreSQL conf_opts table)
MCP_PORT=3100

# Optional: service paths for filesystem tools
HERIKA_SERVER_PATH=/var/www/html/HerikaServer
STOBE_SERVER_PATH=/var/www/html/StobeServer
